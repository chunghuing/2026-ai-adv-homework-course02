<div id="app">
  <h1 class="text-2xl font-bold text-ink mb-6" style="font-family: 'Noto Serif TC', serif;">購物車</h1>

  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-4 border-ink border-t-transparent rounded-full animate-spin"></div>
  </div>

  <div v-else-if="items.length === 0" class="text-center py-12">
    <div class="text-4xl mb-3">&#128722;</div>
    <p class="text-fg-secondary mb-1">購物車是空的</p>
    <p class="text-fg-muted text-sm mb-4">快去挑選喜歡的花束吧！</p>
    <a href="/" class="inline-block bg-ink text-paper-light px-6 py-2.5 rounded text-sm hover:bg-ink-soft transition-colors">去逛逛</a>
  </div>

  <template v-else>
    <!-- Free shipping banner -->
    <div v-if="total < 500" class="bg-paper-light border border-line p-3 mb-6 text-sm text-mulberry text-center">
      &#127803; 再買 NT$ {{ (500 - total).toLocaleString() }} 即可享免運費！
    </div>
    <div v-else class="bg-paper-light border border-moss/40 p-3 mb-6 text-sm text-moss text-center">
      &#10003; 已達免運門檻！
    </div>

    <!-- Cart Items -->
    <div class="bg-paper-light border border-line mb-6">
      <div
        v-for="(item, idx) in items"
        :key="item.id"
        class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4 p-4"
        :class="idx < items.length - 1 ? 'border-b border-line' : ''"
      >
        <div class="flex items-center gap-4 flex-1 min-w-0">
          <img
            :src="item.product.image_url || 'https://images.unsplash.com/photo-1596309322315-da9e713cbb22?w=100'"
            :alt="item.product.name"
            class="w-16 h-16 border border-line object-cover flex-shrink-0"
          />
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-fg-primary text-sm truncate" style="font-family: 'Noto Serif TC', serif;">{{ item.product.name }}</h3>
            <p class="text-mulberry text-sm" style="font-family: 'Fraunces', serif;">NT$ {{ item.product.price.toLocaleString() }}</p>
          </div>
        </div>

        <div class="flex items-center justify-between sm:justify-end gap-4 sm:gap-6 pl-0 sm:pl-0">
          <!-- Quantity Controls -->
          <div class="flex items-center border border-line overflow-hidden flex-shrink-0">
            <button
              @click="updateQuantity(item.id, item.quantity - 1)"
              :disabled="item.quantity <= 1"
              class="w-8 h-8 flex items-center justify-center hover:bg-paper text-fg-secondary text-sm disabled:opacity-40"
            >
              −
            </button>
            <span class="w-8 h-8 flex items-center justify-center text-sm border-x border-line">
              {{ item.quantity }}
            </span>
            <button
              @click="updateQuantity(item.id, item.quantity + 1)"
              :disabled="item.quantity >= item.product.stock"
              class="w-8 h-8 flex items-center justify-center hover:bg-paper text-fg-secondary text-sm disabled:opacity-40 disabled:cursor-not-allowed"
            >
              +
            </button>
          </div>

          <p class="text-fg-primary font-semibold text-sm w-20 sm:w-24 text-right flex-shrink-0" style="font-family: 'Fraunces', serif;">
            NT$ {{ (item.product.price * item.quantity).toLocaleString() }}
          </p>

          <button
            @click="confirmDelete(item.id)"
            class="text-fg-muted hover:text-mulberry transition-colors text-sm flex-shrink-0"
          >
            &#128465;
          </button>
        </div>
      </div>
    </div>

    <!-- Summary -->
    <div class="flex justify-end">
      <div class="bg-paper-light border border-line p-6 w-full max-w-md">
        <div class="flex justify-between items-center mb-2 text-sm">
          <span class="text-fg-secondary">商品小計</span>
          <span class="text-fg-primary">NT$ {{ total.toLocaleString() }}</span>
        </div>
        <div class="flex justify-between items-center mb-4 text-sm">
          <span class="text-fg-secondary">運費</span>
          <span class="text-fg-primary">{{ total >= 500 ? '免運' : 'NT$ 150' }}</span>
        </div>
        <div class="border-t border-line pt-4 flex justify-between items-center">
          <span class="font-bold text-fg-primary">總計</span>
          <span class="font-bold text-xl text-mulberry" style="font-family: 'Fraunces', serif;">
            NT$ {{ (total + (total >= 500 ? 0 : 150)).toLocaleString() }}
          </span>
        </div>
        <button
          @click="goCheckout"
          class="w-full mt-4 bg-ink text-paper-light py-3.5 rounded text-sm font-medium hover:bg-ink-soft transition-colors"
        >
          前往結帳
        </button>
      </div>
    </div>
  </template>

  <!-- Confirm Dialog -->
  <div v-if="confirmVisible" class="fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-ink/50" @click="confirmVisible = false"></div>
    <div class="relative bg-paper-light border border-line shadow-xl w-full max-w-sm mx-4 p-6 text-center">
      <h3 class="text-lg font-semibold text-fg-primary mb-2" style="font-family: 'Noto Serif TC', serif;">確認移除</h3>
      <p class="text-fg-secondary text-sm mb-6">確定要從購物車中移除這個商品嗎？</p>
      <div class="flex gap-3 justify-center">
        <button @click="confirmVisible = false" class="px-4 py-2 text-sm border border-line text-fg-secondary hover:bg-paper">取消</button>
        <button @click="handleDelete" class="px-4 py-2 text-sm bg-mulberry text-white hover:bg-mulberry-dark">確認移除</button>
      </div>
    </div>
  </div>
</div>
