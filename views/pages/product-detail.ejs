<div id="app" data-product-id="<%= productId %>">
  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-4 border-ink border-t-transparent rounded-full animate-spin"></div>
  </div>

  <div v-else-if="notFound" class="text-center py-16">
    <div class="text-5xl mb-4">&#127804;</div>
    <h2 class="text-xl font-medium text-fg-primary mb-2">找不到此商品</h2>
    <a href="/" class="text-mulberry hover:text-mulberry-dark text-sm">回到首頁</a>
  </div>

  <div v-else-if="product" class="flex flex-col md:flex-row gap-10 md:gap-16">
    <!-- Left: Image -->
    <div class="md:w-1/2">
      <div class="relative border border-line">
        <span class="absolute top-0 left-0 z-10 bg-ink text-paper-light text-[11px] tracking-wide px-3.5 py-1.5" style="font-family: 'IBM Plex Mono', monospace;">NO. 01</span>
        <img
          :src="product.image_url || 'https://images.unsplash.com/photo-1596309322315-da9e713cbb22?w=600'"
          :alt="product.name"
          class="w-full aspect-square object-cover"
        />
      </div>
    </div>

    <!-- Right: Info -->
    <div class="md:w-1/2">
      <div class="flex items-center gap-3 mb-4">
        <span class="italic text-ochre" style="font-family: 'Fraunces', serif;">01</span>
        <span class="w-10 h-px bg-line"></span>
        <span class="text-[11px] tracking-[0.2em] text-fg-muted" style="font-family: 'IBM Plex Mono', monospace;">SPECIMEN DETAIL</span>
      </div>
      <h1 class="text-2xl md:text-3xl font-extrabold text-ink mb-3" style="font-family: 'Noto Serif TC', serif;">
        {{ product.name }}
      </h1>
      <p class="text-3xl text-mulberry font-bold mb-4" style="font-family: 'Fraunces', serif;">NT$ {{ product.price.toLocaleString() }}</p>

      <div class="mb-6">
        <span class="text-moss text-sm">&#10003; 尚有 {{ product.stock }} 件</span>
      </div>

      <p class="text-fg-secondary leading-loose mb-6">{{ product.description }}</p>

      <!-- Quantity Selector -->
      <div class="flex items-center gap-4 mb-6">
        <span class="text-sm text-fg-secondary">數量</span>
        <div class="flex items-center border border-line overflow-hidden">
          <button
            @click="decrease"
            class="w-10 h-10 flex items-center justify-center hover:bg-paper text-fg-secondary transition-colors"
          >
            −
          </button>
          <span class="w-12 h-10 flex items-center justify-center text-sm border-x border-line">
            {{ quantity }}
          </span>
          <button
            @click="increase"
            class="w-10 h-10 flex items-center justify-center hover:bg-paper text-fg-secondary transition-colors"
          >
            +
          </button>
        </div>
      </div>

      <button
        @click="addToCart"
        :disabled="adding || product.stock <= 0"
        class="w-full bg-ink text-paper-light py-3.5 rounded text-sm font-medium hover:bg-ink-soft transition-colors disabled:opacity-50"
      >
        {{ product.stock <= 0 ? '已售完' : '加入購物車' }}
      </button>

      <!-- Purchase Notes -->
      <div class="mt-8 bg-paper-light border border-line p-5">
        <h3 class="font-semibold text-fg-primary mb-2.5 text-sm" style="font-family: 'Noto Serif TC', serif;">購買須知</h3>
        <ul class="text-fg-muted text-xs space-y-1.5">
          <li>－ 花材依據季節供應，實際花束可能略有差異</li>
          <li>－ 台北市區可享當日配送服務</li>
          <li>－ 消費滿 NT$ 500 享免運優惠</li>
        </ul>
      </div>
    </div>
  </div>
</div>
