<div id="app">
  <h1 class="text-2xl font-bold text-ink mb-6" style="font-family: 'Noto Serif TC', serif;">我的訂單</h1>

  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-4 border-ink border-t-transparent rounded-full animate-spin"></div>
  </div>

  <div v-else-if="orders.length === 0" class="text-center py-12">
    <div class="text-4xl mb-3">&#128230;</div>
    <p class="text-fg-secondary mb-1">尚無訂單</p>
    <p class="text-fg-muted text-sm mb-4">快去選購喜歡的花束吧！</p>
    <a href="/" class="inline-block bg-ink text-paper-light px-6 py-2.5 rounded text-sm hover:bg-ink-soft transition-colors">去逛逛</a>
  </div>

  <div v-else class="space-y-4">
    <a
      v-for="order in orders"
      :key="order.id"
      :href="'/orders/' + order.id"
      class="block bg-paper-light border border-line p-5 hover:border-ink transition-colors"
    >
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-fg-secondary">訂單編號：{{ order.order_no }}</p>
          <p class="text-xs text-fg-muted mt-1" style="font-family: 'IBM Plex Mono', monospace;">{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</p>
        </div>
        <div class="flex items-center gap-4">
          <span class="font-bold text-fg-primary" style="font-family: 'Fraunces', serif;">NT$ {{ order.total_amount.toLocaleString() }}</span>
          <span
            class="text-[11px] px-3.5 py-1.5 rounded-full font-semibold tracking-wide"
            :class="statusMap[order.status]?.cls || 'bg-fg-muted/20 text-fg-muted'"
          >
            {{ statusMap[order.status]?.label || order.status }}
          </span>
          <span class="text-fg-muted">&#8594;</span>
        </div>
      </div>
    </a>
  </div>
</div>
