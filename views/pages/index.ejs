<div id="app">
  <!-- Hero -->
  <section class="flex flex-col md:flex-row md:items-center gap-10 md:gap-12 py-10 md:py-16 -mx-4 px-4 md:px-0 md:mx-0">
    <div class="w-full flex-1 min-w-0 text-center md:text-left">
      <div class="flex items-center justify-center md:justify-start gap-3 mb-5">
        <span class="italic text-ochre" style="font-family: 'Fraunces', serif;">01</span>
        <span class="w-10 h-px bg-line"></span>
        <span class="text-[11px] tracking-[0.2em] text-fg-muted" style="font-family: 'IBM Plex Mono', monospace;">PLANT JOURNAL VOL. 06</span>
      </div>
      <h1 class="text-3xl md:text-[2.75rem] leading-[1.3] font-extrabold text-ink mb-5" style="font-family: 'Noto Serif TC', serif;">
        讓花裝點生活每一刻
      </h1>
      <p class="text-fg-secondary mb-8 leading-loose max-w-md mx-auto md:mx-0">
        精選當季鮮花，由專業花藝師手工包裝。每一束花都傳遞著溫暖與祝福，為您的生活增添色彩與芬芳。
      </p>
      <a href="#products" class="inline-block bg-ink text-paper-light px-8 py-3.5 rounded text-sm font-medium hover:bg-ink-soft transition-colors">
        立即選購 →
      </a>
    </div>
    <div class="flex-1 min-w-0 max-w-md w-full mx-auto">
      <div class="relative border border-line">
        <img
          src="https://images.unsplash.com/photo-1677768062220-32f1658715c4?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=900"
          alt="花束"
          class="w-full aspect-[4/5] object-cover"
        />
        <span class="absolute top-0 left-0 bg-ink text-paper-light text-[11px] tracking-wide px-3.5 py-1.5" style="font-family: 'IBM Plex Mono', monospace;">標本 NO. 01</span>
        <span class="absolute bottom-4 right-4 bg-paper-light border border-line px-4 py-2 italic text-mulberry text-xs" style="font-family: 'Fraunces', serif;">Rosa &middot; 台北花市直送</span>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="mb-20">
    <div class="flex items-center gap-3 mb-3">
      <span class="italic text-ochre" style="font-family: 'Fraunces', serif;">02</span>
      <span class="w-10 h-px bg-line"></span>
      <span class="text-[11px] tracking-[0.2em] text-fg-muted" style="font-family: 'IBM Plex Mono', monospace;">SELECTED SPECIMENS</span>
    </div>
    <div class="flex items-end justify-between mb-7">
      <div>
        <h2 class="text-2xl font-bold text-ink" style="font-family: 'Noto Serif TC', serif;">精選推薦</h2>
        <p class="text-fg-muted text-sm mt-1.5">本季最受歡迎的花卉精選</p>
      </div>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <div
        v-for="(product, idx) in products.slice(0, 4)"
        :key="product.id"
        class="bg-paper-light border border-line cursor-pointer group"
        @click="goToProduct(product.id)"
      >
        <div class="relative aspect-square overflow-hidden">
          <span class="absolute top-0 left-0 z-10 bg-ink text-paper-light text-[10px] tracking-wide px-2.5 py-1" style="font-family: 'IBM Plex Mono', monospace;">
            NO. {{ String(idx + 1).padStart(2, '0') }}
          </span>
          <img
            :src="product.image_url || featuredImages[idx % 4]"
            :alt="product.name"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
        </div>
        <div class="p-4">
          <h3 class="font-semibold text-sm text-fg-primary truncate mb-1" style="font-family: 'Noto Serif TC', serif;">{{ product.name }}</h3>
          <p class="text-mulberry font-bold" style="font-family: 'Fraunces', serif;">NT$ {{ product.price.toLocaleString() }}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Brand Story -->
  <section class="mb-20 -mx-4 md:mx-0 bg-ink text-paper-light">
    <div class="flex flex-col md:flex-row">
      <div class="md:w-1/2">
        <img
          src="https://images.unsplash.com/photo-1709294728779-6be509d45255?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=900"
          alt="花藝師"
          class="w-full h-64 md:h-full object-cover"
        />
      </div>
      <div class="md:w-1/2 p-8 md:p-14 flex flex-col justify-center">
        <div class="flex items-center gap-3 mb-5">
          <span class="italic text-ochre" style="font-family: 'Fraunces', serif;">03</span>
          <span class="w-10 h-px bg-line-on-ink"></span>
          <span class="text-[11px] tracking-[0.2em] text-paper-light" style="font-family: 'IBM Plex Mono', monospace;">OUR STORY</span>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-paper-light mb-5" style="font-family: 'Noto Serif TC', serif;">
          專心，做好一束花的感動
        </h2>
        <p class="text-fg-on-ink leading-loose mb-5 max-w-md">
          花漾生活成立於 2020 年，我們相信每一朵花都有自己的故事。透過專業花藝師的巧手，將大自然的美好帶進您的日常生活中。
        </p>
        <p class="text-ochre text-sm italic" style="font-family: 'Fraunces', serif;">
          「每一束花，都是一份用心的禮物。」
        </p>
      </div>
    </div>
  </section>

  <!-- All Products Grid -->
  <section id="products" class="mb-20">
    <div class="flex items-center gap-3 mb-3">
      <span class="italic text-ochre" style="font-family: 'Fraunces', serif;">04</span>
      <span class="w-10 h-px bg-line"></span>
      <span class="text-[11px] tracking-[0.2em] text-fg-muted" style="font-family: 'IBM Plex Mono', monospace;">THE FULL COLLECTION</span>
    </div>
    <h2 class="text-2xl font-bold text-ink mb-1.5" style="font-family: 'Noto Serif TC', serif;">探索所有花藝</h2>
    <p class="text-fg-muted text-sm mb-8">找到屬於您的那束花</p>

    <div v-if="loading" class="flex justify-center py-12">
      <div class="w-8 h-8 border-4 border-ink border-t-transparent rounded-full animate-spin"></div>
    </div>

    <template v-else>
      <div v-if="products.length === 0" class="text-center py-12">
        <div class="text-4xl mb-3">&#127804;</div>
        <p class="text-fg-secondary">目前沒有商品</p>
        <p class="text-fg-muted text-sm">請稍後再來看看</p>
      </div>

      <div v-else class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div
          v-for="(product, idx) in products"
          :key="product.id"
          @click="goToProduct(product.id)"
          class="bg-paper-light border border-line cursor-pointer group"
        >
          <div class="relative aspect-square overflow-hidden">
            <span class="absolute top-0 left-0 z-10 bg-ink text-paper-light text-[10px] tracking-wide px-2.5 py-1" style="font-family: 'IBM Plex Mono', monospace;">
              NO. {{ String(idx + 1).padStart(2, '0') }}
            </span>
            <img
              :src="product.image_url || 'https://images.unsplash.com/photo-1604137488398-b1d691713d96?w=400'"
              :alt="product.name"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
          </div>
          <div class="p-4">
            <h3 class="font-semibold text-fg-primary mb-1 truncate" style="font-family: 'Noto Serif TC', serif;">{{ product.name }}</h3>
            <div class="flex items-center justify-between mb-3">
              <p class="text-mulberry font-bold text-lg" style="font-family: 'Fraunces', serif;">NT$ {{ product.price.toLocaleString() }}</p>
              <p class="text-moss text-[11px]">尚有 {{ product.stock }} 件</p>
            </div>
            <button
              @click.stop="addToCart(product)"
              :disabled="product._adding || product.stock <= 0"
              class="w-full bg-ink text-paper-light py-2.5 rounded text-sm hover:bg-ink-soft transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            >
              {{ product.stock <= 0 ? '已售完' : '加入購物車' }}
            </button>
          </div>
        </div>
      </div>

      <!-- Pagination -->
      <div v-if="pagination.totalPages > 1" class="flex justify-center gap-3 mt-10">
        <button
          v-for="p in pagination.totalPages"
          :key="p"
          @click="loadProducts(p)"
          class="w-10 h-10 border text-sm transition-colors"
          style="font-family: 'Fraunces', serif;"
          :class="p === pagination.page ? 'bg-ink text-paper-light border-ink' : 'bg-transparent text-fg-secondary border-line hover:border-ink'"
        >
          {{ p }}
        </button>
      </div>
    </template>
  </section>

  <!-- Customer Testimonials -->
  <section class="mb-16">
    <div class="flex items-center gap-3 mb-3">
      <span class="italic text-ochre" style="font-family: 'Fraunces', serif;">05</span>
      <span class="w-10 h-px bg-line"></span>
      <span class="text-[11px] tracking-[0.2em] text-fg-muted" style="font-family: 'IBM Plex Mono', monospace;">FIELD NOTES</span>
    </div>
    <h2 class="text-2xl font-bold text-ink mb-8" style="font-family: 'Noto Serif TC', serif;">顧客花束好評分享</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-paper-light border border-line p-6">
        <div class="text-ochre mb-3 tracking-widest">★ ★ ★ ★ ★</div>
        <p class="text-fg-secondary text-sm mb-5 leading-relaxed">「花束非常漂亮，包裝精緻，送給媽媽她超開心的！配送也很準時。」</p>
        <p class="text-fg-muted text-xs italic" style="font-family: 'Fraunces', serif;">— 小美</p>
      </div>
      <div class="bg-paper-light border border-line p-6">
        <div class="text-ochre mb-3 tracking-widest">★ ★ ★ ★ ★</div>
        <p class="text-fg-secondary text-sm mb-5 leading-relaxed">「第二次購買了，品質一如既往的好。花材新鮮，整體搭配很有美感。」</p>
        <p class="text-fg-muted text-xs italic" style="font-family: 'Fraunces', serif;">— 阿明</p>
      </div>
      <div class="bg-paper-light border border-line p-6">
        <div class="text-ochre mb-3 tracking-widest">★ ★ ★ ★ ★</div>
        <p class="text-fg-secondary text-sm mb-5 leading-relaxed">「女朋友收到花束超感動！會再回購的，推薦給大家！」</p>
        <p class="text-fg-muted text-xs italic" style="font-family: 'Fraunces', serif;">— 大衛</p>
      </div>
    </div>
  </section>

  <!-- Service Features -->
  <section class="mb-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
      <div class="bg-paper-light border border-line p-8">
        <div class="w-13 h-13 mx-auto mb-4 rounded-full bg-ink flex items-center justify-center" style="width:52px;height:52px;">
          <span class="text-paper-light text-xl">&#128666;</span>
        </div>
        <h3 class="font-semibold text-fg-primary mb-1" style="font-family: 'Noto Serif TC', serif;">快速配送</h3>
        <p class="text-fg-muted text-sm">台北市區當日配送</p>
      </div>
      <div class="bg-paper-light border border-line p-8">
        <div class="mx-auto mb-4 rounded-full bg-ink flex items-center justify-center" style="width:52px;height:52px;">
          <span class="text-paper-light text-xl">&#127873;</span>
        </div>
        <h3 class="font-semibold text-fg-primary mb-1" style="font-family: 'Noto Serif TC', serif;">精美包裝</h3>
        <p class="text-fg-muted text-sm">每束花都經過精心包裝</p>
      </div>
      <div class="bg-paper-light border border-line p-8">
        <div class="mx-auto mb-4 rounded-full bg-ink flex items-center justify-center" style="width:52px;height:52px;">
          <span class="text-paper-light text-xl">&#127811;</span>
        </div>
        <h3 class="font-semibold text-fg-primary mb-1" style="font-family: 'Noto Serif TC', serif;">滿額免運</h3>
        <p class="text-fg-muted text-sm">消費滿 NT$ 500 免運費</p>
      </div>
    </div>
  </section>
</div>
