<div id="app" data-order-id="<%= orderId %>" data-payment-result="<%= paymentResult %>">
  <h1 class="text-2xl font-bold text-ink mb-6" style="font-family: 'Noto Serif TC', serif;">訂單詳情</h1>

  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-4 border-ink border-t-transparent rounded-full animate-spin"></div>
  </div>

  <template v-else-if="order">
    <!-- Payment Result Alert -->
    <div
      v-if="paymentResult && paymentMessages[paymentResult]"
      class="border p-4 mb-6 text-sm"
      :class="paymentMessages[paymentResult].cls"
    >
      {{ paymentMessages[paymentResult].text }}
    </div>

    <!-- Order Info -->
    <div class="bg-paper-light border border-line p-6 mb-6">
      <div class="flex items-start justify-between">
        <div>
          <p class="text-sm text-fg-secondary">訂單編號：{{ order.order_no }}</p>
          <p class="text-xs text-fg-muted mt-1" style="font-family: 'IBM Plex Mono', monospace;">建立日期：{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</p>
        </div>
        <span
          class="text-[11px] px-3.5 py-1.5 rounded-full font-semibold tracking-wide"
          :class="statusMap[order.status]?.cls || 'bg-fg-muted/20 text-fg-muted'"
        >
          {{ statusMap[order.status]?.label || order.status }}
        </span>
      </div>
    </div>

    <!-- Recipient Info -->
    <div class="bg-paper-light border border-line p-6 mb-6">
      <h2 class="font-semibold text-fg-primary mb-3" style="font-family: 'Noto Serif TC', serif;">收件資訊</h2>
      <div class="text-sm space-y-2 text-fg-secondary">
        <p>收件人：{{ order.recipient_name }}</p>
        <p>Email：{{ order.recipient_email }}</p>
        <p>地址：{{ order.recipient_address }}</p>
      </div>
    </div>

    <!-- Order Items -->
    <div class="bg-paper-light border border-line p-6 mb-6">
      <h2 class="font-semibold text-fg-primary mb-3" style="font-family: 'Noto Serif TC', serif;">商品明細</h2>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-line text-fg-muted">
            <th class="text-left py-2 font-normal text-xs tracking-wide" style="font-family: 'IBM Plex Mono', monospace;">商品名稱</th>
            <th class="text-right py-2 font-normal text-xs tracking-wide" style="font-family: 'IBM Plex Mono', monospace;">單價</th>
            <th class="text-right py-2 font-normal text-xs tracking-wide" style="font-family: 'IBM Plex Mono', monospace;">數量</th>
            <th class="text-right py-2 font-normal text-xs tracking-wide" style="font-family: 'IBM Plex Mono', monospace;">小計</th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="item in order.items" :key="item.id" class="border-b border-line/60">
            <td class="py-3 text-fg-primary">{{ item.product_name }}</td>
            <td class="py-3 text-right text-fg-secondary">NT$ {{ item.product_price.toLocaleString() }}</td>
            <td class="py-3 text-right text-fg-secondary">{{ item.quantity }}</td>
            <td class="py-3 text-right text-fg-primary font-medium">NT$ {{ (item.product_price * item.quantity).toLocaleString() }}</td>
          </tr>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="3" class="pt-3 text-right font-bold text-fg-primary">總計</td>
            <td class="pt-3 text-right font-bold text-mulberry text-lg" style="font-family: 'Fraunces', serif;">NT$ {{ order.total_amount.toLocaleString() }}</td>
          </tr>
        </tfoot>
      </table>
    </div>

    <!-- Payment Actions -->
    <div v-if="order.status === 'pending'" class="flex gap-4">
      <button
        @click="checkPayment"
        :disabled="paying"
        class="border border-moss text-moss px-8 py-3 rounded text-sm font-medium hover:bg-moss hover:text-white transition-colors disabled:opacity-50"
      >
        {{ paying ? '查詢中...' : '查詢付款狀態' }}
      </button>
      <a
        :href="'/ecpay/payment/' + order.id"
        class="inline-block bg-ink text-paper-light px-8 py-3 rounded text-sm font-medium hover:bg-ink-soft transition-colors text-center"
      >
        前往付款
      </a>
    </div>
  </template>
</div>
